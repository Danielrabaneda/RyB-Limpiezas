rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // =========================================================================
    // HELPER FUNCTIONS (Custom Claims based, zero Firestore reads)
    // =========================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isTenant(companyId) {
      return isAuthenticated() && 
        request.auth.token.companyId == companyId && 
        request.auth.token.active == true;
    }

    function isTenantAdmin(companyId) {
      return isTenant(companyId) && request.auth.token.role == 'admin';
    }

    function isTenantEmployee(companyId) {
      return isTenant(companyId) && 
        (request.auth.token.role == 'admin' || request.auth.token.role == 'operario');
    }

    // =========================================================================
    // MULTI-TENANT STORAGE MATCHERS
    // =========================================================================

    // Invoices: tenant-scoped
    match /companies/{companyId}/invoices/{invoiceId}/{fileName} {
      allow read, write: if isTenantAdmin(companyId);
    }

    // Evidence, Guides and Absence Proofs: tenant-scoped
    match /companies/{companyId}/evidence/{userId}/{serviceId}/{fileName} {
      allow write: if isTenantEmployee(companyId) && request.auth.uid == userId
                   && request.resource.size < 20 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
      allow read: if isTenantEmployee(companyId) && (
        request.auth.uid == userId || 
        request.auth.token.role == 'admin' || 
        serviceId.matches('guides_.*')
      );
    }
    
    // Logos: tenant-scoped, public read, admin-only write
    match /companies/{companyId}/logos/{fileName} {
      allow read: if true;
      allow write: if isTenantAdmin(companyId);
    }

    // =========================================================================
    // LEGACY / GLOBAL FALLBACKS (For backward compatibility, locked down where possible)
    // =========================================================================

    // Legacy logos (root folder)
    match /logos/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.token.role == 'admin' && request.auth.token.active == true;
    }

    // Legacy evidence (root folder)
    match /evidence/{userId}/{serviceId}/{fileName} {
      allow read, write: if false; // Locked down to force multi-tenant paths!
    }

    // Legacy invoices (root folder)
    match /invoices/{invoiceId}/{fileName} {
      allow read, write: if false; // Locked down to force multi-tenant paths!
    }

    // Default deny-all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
