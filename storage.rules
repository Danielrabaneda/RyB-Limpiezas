rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if the user has 'admin' role in Firestore
    function isAdmin() {
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Evidence photos: organized by userId/serviceId
    match /evidence/{userId}/{serviceId}/{fileName} {
      // Operario can upload to their own folder
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 20 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      // Admin can read all, operario can read own
      allow read: if request.auth != null;
    }
    
    // Logos: public read, admin-only write
    match /logos/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Invoices: authenticated-only read/write
    match /invoices/{invoiceId}/{fileName} {
      allow read, write: if request.auth != null;
    }
    
    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
