rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================================
    // FUNCTIONS
    // =========================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Role check: Admin
    // Using a get() to the users collection ensures we check the actual DB role
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if the document belongs to the requesting user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the user is a registered employee (admin or operario)
    function isEmployee() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'operario');
    }

    // Check if the user is active in the database
    function isActiveUser() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }

    // Helper to check if the user is an active employee
    function isEmployeeActive() {
      return isEmployee() && isActiveUser();
    }

    // Helper to check if the user is an active admin
    function isAdminActive() {
      return isAdmin() && isActiveUser();
    }

    // =========================================================================
    // FUNCIONES DE CONTROL PARALELAS (NUEVAS - BASADAS EN CLAIMS)
    // =========================================================================
    function isAdminClaim() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }

    function isEmployeeClaim() {
      return isAuthenticated() && 
        (request.auth.token.role == 'admin' || request.auth.token.role == 'operario');
    }

    function isActiveUserClaim() {
      return isAuthenticated() && request.auth.token.active == true;
    }

    function isEmployeeActiveClaim() {
      return isEmployeeClaim() && isActiveUserClaim();
    }

    function isAdminActiveClaim() {
      return isAdminClaim() && isActiveUserClaim();
    }

    // =========================================================================
    // RULES
    // =========================================================================
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // GEO DETECTIONS & FCM TOKENS
    // -------------------------------------------------------------------------
    match /geoDetections/{detectionId} {
      allow read: if isAdminActiveClaim() || (isEmployeeActiveClaim() && resource.data.userId == request.auth.uid);
      allow create, update: if isEmployeeActiveClaim() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdminActiveClaim();
    }

    match /fcmTokens/{tokenId} {
      allow read: if isAdminActiveClaim() || (isEmployeeActiveClaim() && resource.data.userId == request.auth.uid);
      allow create, update: if isEmployeeActiveClaim() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdminActiveClaim() || (isEmployeeActiveClaim() && resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      // Admins can do anything
      // Operarios need to read the list of other operarios to select companions
      allow read: if isEmployeeActiveClaim(); 
      // Permitir la creación de perfiles si el usuario se registra a sí mismo como operario o si es un admin activo
      allow create: if isAdminActiveClaim() || (isAuthenticated() && isOwner(userId) && request.resource.data.role == 'operario');
      allow delete: if isAdminActiveClaim();
      // Users can update their own profile (e.g. push tokens, active status), 
      // but preventing role escalation would require checking request.resource.data.role
      allow update: if isAdminActiveClaim() || (isEmployeeActiveClaim() && isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    // -------------------------------------------------------------------------
    // ACCESS CODES (Invitaciones para registro)
    // -------------------------------------------------------------------------
    match /accessCodes/{code} {
      // Permitir a cualquiera comprobar si un código específico es válido (get)
      // pero no listar todos los códigos (list) ni modificarlos (write)
      allow get: if true;
      allow list, write: if isAdminActiveClaim();
    }

    // -------------------------------------------------------------------------
    // COMMUNITIES & TASKS (Global Config)
    // -------------------------------------------------------------------------
    match /communities/{communityId} {
      allow read: if isEmployeeActiveClaim();
      allow write: if isAdminActiveClaim();
    }

    match /taskTemplates/{templateId} {
      allow read: if isEmployeeActiveClaim();
      allow write: if isAdminActiveClaim();
    }

    match /communityTasks/{taskId} {
      allow read: if isEmployeeActiveClaim();
      allow write: if isAdminActiveClaim();
    }

    match /assignments/{assignmentId} {
      allow read: if isEmployeeActiveClaim();
      allow write: if isAdminActiveClaim();
    }

    // -------------------------------------------------------------------------
    // SCHEDULED SERVICES
    // -------------------------------------------------------------------------
    match /scheduledServices/{serviceId} {
      // Only authenticated users can read schedules
      allow read, update: if isEmployeeActiveClaim();
      allow create, delete: if isAdminActiveClaim();
    }

    // -------------------------------------------------------------------------
    // GPS SUGGESTIONS (Colección de prueba - Custom Claims)
    // -------------------------------------------------------------------------
    match /gpsSuggestions/{suggestionId} {
      allow read: if isAdminActiveClaim() || (isEmployeeActiveClaim() && (resource.data.operarioUid == request.auth.uid || resource.data.userId == request.auth.uid));
      allow create: if isEmployeeActiveClaim();
      allow update, delete: if isAdminActiveClaim();
    }

    // -------------------------------------------------------------------------
    // USER SPECIFIC DATA (Workdays, Check-ins, Mileage, etc.)
    // -------------------------------------------------------------------------
    
    match /workdays/{workdayId} {
      allow read: if isAdminActiveClaim() || (isEmployeeActiveClaim() && (isOwner(resource.data.userId) || resource.data.currentCompanionId == request.auth.uid));
      allow create: if isEmployeeActiveClaim() && isOwner(request.resource.data.userId);
      allow update: if isAdminActiveClaim() || (isEmployeeActiveClaim() && isOwner(resource.data.userId));
      allow delete: if isAdminActiveClaim();
    }

    match /checkIns/{checkInId} {
      allow read: if isAdminActiveClaim() || (isEmployeeActiveClaim() && (
        isOwner(resource.data.userId) ||
        (
          'scheduledServiceId' in resource.data && 
          resource.data.scheduledServiceId != null && 
          resource.data.scheduledServiceId != '' && 
          (
            get(/databases/$(database)/documents/scheduledServices/$(resource.data.scheduledServiceId)).data.assignedUserId == request.auth.uid ||
            (
              'companionIds' in get(/databases/$(database)/documents/scheduledServices/$(resource.data.scheduledServiceId)).data &&
              request.auth.uid in get(/databases/$(database)/documents/scheduledServices/$(resource.data.scheduledServiceId)).data.companionIds
            )
          )
        )
      ));
      allow create: if isEmployeeActiveClaim() && (
        isOwner(request.resource.data.userId) ||
        (
          'scheduledServiceId' in request.resource.data && 
          request.resource.data.scheduledServiceId != null && 
          request.resource.data.scheduledServiceId != '' && 
          (
            get(/databases/$(database)/documents/scheduledServices/$(request.resource.data.scheduledServiceId)).data.assignedUserId == request.auth.uid ||
            (
              'companionIds' in get(/databases/$(database)/documents/scheduledServices/$(request.resource.data.scheduledServiceId)).data &&
              request.auth.uid in get(/databases/$(database)/documents/scheduledServices/$(request.resource.data.scheduledServiceId)).data.companionIds
            )
          ) &&
          (
            request.resource.data.userId == get(/databases/$(database)/documents/scheduledServices/$(request.resource.data.scheduledServiceId)).data.assignedUserId ||
            (
              'companionIds' in get(/databases/$(database)/documents/scheduledServices/$(request.resource.data.scheduledServiceId)).data &&
              request.resource.data.userId in get(/databases/$(database)/documents/scheduledServices/$(request.resource.data.scheduledServiceId)).data.companionIds
            )
          )
        )
      );
      allow update, delete: if isEmployeeActiveClaim() && (
        isAdminActiveClaim() || 
        isOwner(resource.data.userId) ||
        (
          'scheduledServiceId' in resource.data && 
          resource.data.scheduledServiceId != null && 
          resource.data.scheduledServiceId != '' && 
          (
            get(/databases/$(database)/documents/scheduledServices/$(resource.data.scheduledServiceId)).data.assignedUserId == request.auth.uid ||
            (
              'companionIds' in get(/databases/$(database)/documents/scheduledServices/$(resource.data.scheduledServiceId)).data &&
              request.auth.uid in get(/databases/$(database)/documents/scheduledServices/$(resource.data.scheduledServiceId)).data.companionIds
            )
          )
        )
      );
    }

    match /dailyMileage/{mileageId} {
      allow read: if isAdminActiveClaim() || (isEmployeeActiveClaim() && isOwner(resource.data.userId));
      allow create: if isEmployeeActiveClaim() && isOwner(request.resource.data.userId);
      allow update: if isAdminActiveClaim() || (isEmployeeActiveClaim() && isOwner(resource.data.userId));
      allow delete: if isAdminActiveClaim();
    }

    match /materialRequests/{requestId} {
      allow read: if isAdminActiveClaim() || (isEmployeeActiveClaim() && isOwner(resource.data.userId));
      allow create: if isEmployeeActiveClaim() && isOwner(request.resource.data.userId);
      allow update: if isAdminActiveClaim() || (isEmployeeActiveClaim() && isOwner(resource.data.userId));
      allow delete: if isAdminActiveClaim();
    }

    match /reports/{reportId} {
      allow read, write: if isAdminActiveClaim();
    }

    match /transfers/{transferId} {
      allow read: if isAdminActiveClaim() || 
                  (isEmployeeActiveClaim() && (
                    resource.data.fromUserId == request.auth.uid || 
                    resource.data.toUserId == request.auth.uid || 
                    resource.data.userId == request.auth.uid
                  ));
      
      allow create: if isAdminActiveClaim() || (isEmployeeActiveClaim() && 
                    (
                      request.resource.data.fromUserId == request.auth.uid || 
                      request.resource.data.toUserId == request.auth.uid || 
                      request.resource.data.userId == request.auth.uid
                    ));
      
      allow update: if isAdminActiveClaim() || 
                  (isEmployeeActiveClaim() && (
                    resource.data.fromUserId == request.auth.uid || 
                    resource.data.toUserId == request.auth.uid || 
                    resource.data.userId == request.auth.uid
                  ));
      
      allow delete: if isAdminActiveClaim();
    }

    match /systemNotifications/{notificationId} {
      allow read: if isAdminActiveClaim() || (isEmployeeActiveClaim() && isOwner(resource.data.userId));
      allow create: if isAdminActiveClaim() || (isEmployeeActiveClaim() && isOwner(request.resource.data.userId));
      allow update: if isAdminActiveClaim() || (isEmployeeActiveClaim() && isOwner(resource.data.userId));
      allow delete: if isAdminActiveClaim();
    }

    match /taskExecutions/{executionId} {
      allow read, write: if isEmployeeActiveClaim();
    }

    match /settings/{settingId} {
      allow read: if settingId == 'global' ? isEmployeeActiveClaim() : isAdminActiveClaim();
      allow write: if isAdminActiveClaim();
    }

    // VERIFACTU: Inmutabilidad — solo se pueden editar/eliminar borradores.
    // Se permite cambiar solo el campo 'status' (ej. marcar como pagada) en facturas emitidas.
    match /invoices/{invoiceId} {
      allow read, create: if isAdminActiveClaim();
      allow update: if isAdminActiveClaim() && (
        resource.data.status == 'draft' ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isAdminActiveClaim() && resource.data.status == 'draft';
    }

    match /products/{productId} {
      allow read: if isEmployeeActiveClaim();
      allow write: if isAdminActiveClaim();
    }

    match /stockMovements/{movementId} {
      allow read, write: if isAdminActiveClaim();
    }

    match /absences/{absenceId} {
      allow read: if isEmployeeActiveClaim();
      allow create: if isEmployeeActiveClaim() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdminActiveClaim();
    }

    match /invoice_templates/{templateId} {
      allow read, write: if isAdminActiveClaim();
    }

    match /documentVault/{documentId} {
      allow read: if isEmployeeActiveClaim();
      allow write: if isAdminActiveClaim();
    }

    match /evidenceReports/{reportId} {
      allow read: if isAdminActiveClaim() || (isEmployeeActiveClaim() && resource.data.userId == request.auth.uid);
      allow create: if isEmployeeActiveClaim();
      allow update, delete: if isAdminActiveClaim();
    }

    match /publicPortals/{token} {
      allow get: if true;
      allow write, list: if isAdminActiveClaim();
    }

    // -------------------------------------------------------------------------
    // ADMINISTRADORES DE FINCAS
    // -------------------------------------------------------------------------
    match /administrators/{adminId} {
      allow read, write: if isAdminActiveClaim();
    }

    // -------------------------------------------------------------------------
    // COMPANY REQUESTS (Leads de la Landing Page — escritura pública)
    // -------------------------------------------------------------------------
    match /companyRequests/{requestId} {
      allow create: if request.resource.data.keys().hasAll(['companyName', 'contactName', 'email', 'phone']) 
                    && request.resource.data.keys().size() <= 10
                    && request.resource.data.companyName is string && request.resource.data.companyName.size() < 200
                    && request.resource.data.contactName is string && request.resource.data.contactName.size() < 200
                    && request.resource.data.email is string && request.resource.data.email.size() < 200
                    && request.resource.data.phone is string && request.resource.data.phone.size() < 50;
      allow read, update, delete: if isAdminActiveClaim();
    }

    // -------------------------------------------------------------------------
    // OTHER / FUTURE COLLECTIONS
    // -------------------------------------------------------------------------
    // Add explicitly any other collections you use to avoid access denied
  }
}
