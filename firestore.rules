rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================================
    // FUNCTIONS
    // =========================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Role check: Admin
    // Using a get() to the users collection ensures we check the actual DB role
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if the document belongs to the requesting user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }



    // =========================================================================
    // RULES
    // =========================================================================
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // GEO DETECTIONS & FCM TOKENS
    // -------------------------------------------------------------------------
    match /geoDetections/{detectionId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create, update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /fcmTokens/{tokenId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create, update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // -------------------------------------------------------------------------
    // USERS
    // -------------------------------------------------------------------------
    match /users/{userId} {
      // Admins can do anything
      // Operarios need to read the list of other operarios to select companions
      allow read: if isAuthenticated(); 
      // Only Admins can create or delete users
      allow create, delete: if isAdmin();
      // Users can update their own profile (e.g. push tokens, active status), 
      // but preventing role escalation would require checking request.resource.data.role
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    // -------------------------------------------------------------------------
    // COMMUNITIES & TASKS (Global Config)
    // -------------------------------------------------------------------------
    match /communities/{communityId} {
      // Only authenticated users can read communities, except for public get request if portal token is active
      allow get: if isAuthenticated() || resource.data.portalToken != null;
      allow list: if isAuthenticated();
      // Only admins manage communities
      allow write: if isAdmin();
    }

    match /taskTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /communityTasks/{taskId} {
      allow list: if true;
      allow get: if true;
      allow write: if isAdmin();
    }

    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // SCHEDULED SERVICES
    // -------------------------------------------------------------------------
    match /scheduledServices/{serviceId} {
      // Only authenticated users can read schedules
      allow read: if isAuthenticated();
      
      // Admins can manage schedule entirely.
      allow create, delete: if isAdmin();
      
      // Operarios need to update status (e.g., to 'in_progress', 'completed')
      allow update: if isAuthenticated();
    }

    // -------------------------------------------------------------------------
    // GPS SUGGESTIONS
    // -------------------------------------------------------------------------
    match /gpsSuggestions/{suggestionId} {
      // Admins read to review, operarios can read if they want to see their own?
      // Actually safer to allow all authenticated to read, or just admins + owner
      allow read: if isAdmin() || (isAuthenticated() && resource.data.operarioUid == request.auth.uid) || (isAuthenticated() && resource.data.userId == request.auth.uid);
      
      // Operarios create suggestions
      allow create: if isAuthenticated();
      
      // Admins review/delete/update
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // USER SPECIFIC DATA (Workdays, Check-ins, Mileage, etc.)
    // -------------------------------------------------------------------------
    
    match /workdays/{workdayId} {
      // Admins can read all.
      // Owners can read their own.
      // Companions need to be able to read active workdays where they are 'currentCompanionId'
      // The query is: where('currentCompanionId', '==', userId), where('status', '==', 'active')
      allow read: if isAdmin() || isOwner(resource.data.userId) || (isAuthenticated() && resource.data.currentCompanionId == request.auth.uid);
      
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isAdmin() || isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    match /checkIns/{checkInId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAuthenticated() && (isAdmin() || isOwner(resource.data.userId));
      allow delete: if isAuthenticated() && isAdmin();
    }

    match /dailyMileage/{mileageId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isAdmin() || isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    match /materialRequests/{requestId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isAdmin() || isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow list: if request.auth != null || 
        (request.query.limit <= 50 && 
         get(/databases/$(database)/documents/communities/resource.data.communityId).data.portalToken != null);
      allow get: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isAdmin() || isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    match /transfers/{transferId} {
      // A transfer involves a fromUserId and a toUserId, or a userId for date reschedules
      allow read: if isAdmin() || 
                  (isAuthenticated() && (
                    resource.data.fromUserId == request.auth.uid || 
                    resource.data.toUserId == request.auth.uid || 
                    resource.data.userId == request.auth.uid
                  ));
      
      // Both users involved (or the requesting user for date reschedules) can create
      allow create: if isAdmin() || (isAuthenticated() && 
                    (
                      request.resource.data.fromUserId == request.auth.uid || 
                      request.resource.data.toUserId == request.auth.uid || 
                      request.resource.data.userId == request.auth.uid
                    ));
      
      allow update: if isAdmin() || 
                    (isAuthenticated() && (
                      resource.data.fromUserId == request.auth.uid || 
                      resource.data.toUserId == request.auth.uid || 
                      resource.data.userId == request.auth.uid
                    ));
      
      allow delete: if isAdmin();
    }

    match /systemNotifications/{notificationId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      // System functions / admins might create. Operarios might create if they send notifications? 
      // Safe to allow authenticated to create if they set userId to themselves or are admin.
      allow create: if isAdmin() || isOwner(request.resource.data.userId);
      allow update: if isAdmin() || isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    match /taskExecutions/{executionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /stockMovements/{movementId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /absences/{absenceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /invoice_templates/{templateId} {
      allow read, write: if isAdmin();
    }

    match /documentVault/{documentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /evidenceReports/{reportId} {
      allow list: if true;
      allow get: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /publicPortals/{token} {
      allow get: if true;
      allow write, list: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // ADMINISTRADORES DE FINCAS
    // -------------------------------------------------------------------------
    match /administrators/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // OTHER / FUTURE COLLECTIONS
    // -------------------------------------------------------------------------
    // Add explicitly any other collections you use to avoid access denied
  }
}
