rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================================
    // FUNCTIONS
    // =========================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }

    function isEmployee() {
      return isAuthenticated() && 
        (request.auth.token.role == 'admin' || request.auth.token.role == 'operario');
    }

    function isActiveUser() {
      return isAuthenticated() && request.auth.token.active == true;
    }

    function isEmployeeActive() {
      return isEmployee() && isActiveUser();
    }

    function isAdminActive() {
      return isAdmin() && isActiveUser();
    }

    function hasTenant() {
      return isAuthenticated() && request.auth.token.companyId != null;
    }

    function isTenant(companyId) {
      return hasTenant() && request.auth.token.companyId == companyId;
    }

    // =========================================================================
    // RULES
    // =========================================================================
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // ACCESS CODES (Index global para registro)
    // -------------------------------------------------------------------------
    match /accessCodeIndex/{code} {
      // Público solo la lectura puntual (get). No se permite listar.
      allow get: if true;
      allow list, write: if false;
    }

    // -------------------------------------------------------------------------
    // COMPANY REQUESTS (Landing Page leads)
    // -------------------------------------------------------------------------
    match /companyRequests/{requestId} {
      allow create: if request.resource.data.keys().hasAll(['companyName', 'contactName', 'email', 'phone']) 
                    && request.resource.data.keys().size() <= 10
                    && request.resource.data.companyName is string && request.resource.data.companyName.size() < 200
                    && request.resource.data.contactName is string && request.resource.data.contactName.size() < 200
                    && request.resource.data.email is string && request.resource.data.email.size() < 200
                    && request.resource.data.phone is string && request.resource.data.phone.size() < 50;
      allow read, update, delete: if false; 
    }

    // -------------------------------------------------------------------------
    // USERS (Excepción de Raíz)
    // -------------------------------------------------------------------------
    match /users/{userId} {
      // get de otro usuario permitido si están en el mismo tenant
      allow get, list: if isEmployeeActive() && isTenant(resource.data.companyId);
      
      // La creación y borrado la hace exclusivamente el Backend.
      allow create, delete: if false;
      
      // Updates desde el cliente (solo el propio usuario):
      allow update: if isEmployeeActive() && isOwner(userId)
                    // No se pueden modificar propiedades core
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.active == resource.data.active
                    && request.resource.data.companyId == resource.data.companyId;
    }

    // -------------------------------------------------------------------------
    // TENANT ISOLATION (/companies/{companyId}/...)
    // -------------------------------------------------------------------------
    match /companies/{companyId} {
      
      // La regla global a nivel de documento company no permite operaciones en crudo a menos que sea un empleado
      allow read: if isTenant(companyId) && isEmployeeActive();
      allow write: if isTenant(companyId) && isAdminActive();

      // geoDetections
      match /geoDetections/{detectionId} {
        allow read: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && resource.data.userId == request.auth.uid));
        allow create: if isTenant(companyId) && isEmployeeActive() && request.resource.data.userId == request.auth.uid;
        allow update: if isTenant(companyId) && isEmployeeActive() && request.resource.data.userId == request.auth.uid;
        allow delete: if isTenant(companyId) && isAdminActive();
      }

      // fcmTokens
      match /fcmTokens/{tokenId} {
        allow read: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && resource.data.userId == request.auth.uid));
        allow create, update: if isTenant(companyId) && isEmployeeActive() && request.resource.data.userId == request.auth.uid;
        allow delete: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && resource.data.userId == request.auth.uid));
      }

      // accessCodes (Los códigos reales)
      match /accessCodes/{code} {
        allow read: if isTenant(companyId) && isEmployeeActive();
        allow write: if isTenant(companyId) && isAdminActive();
      }

      // communities
      match /communities/{id} {
        allow read: if isTenant(companyId) && isEmployeeActive();
        allow write: if isTenant(companyId) && isAdminActive();
      }

      // taskTemplates
      match /taskTemplates/{id} {
        allow read: if isTenant(companyId) && isEmployeeActive();
        allow write: if isTenant(companyId) && isAdminActive();
      }

      // communityTasks
      match /communityTasks/{id} {
        allow read: if isTenant(companyId) && isEmployeeActive();
        allow write: if isTenant(companyId) && isAdminActive();
      }

      // assignments
      match /assignments/{id} {
        allow read: if isTenant(companyId) && isEmployeeActive();
        allow write: if isTenant(companyId) && isAdminActive();
      }

      // scheduledServices
      match /scheduledServices/{id} {
        allow read, update: if isTenant(companyId) && isEmployeeActive();
        allow create, delete: if isTenant(companyId) && isAdminActive();
      }

      // gpsSuggestions
      match /gpsSuggestions/{id} {
        allow read: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && (resource.data.operarioUid == request.auth.uid || resource.data.userId == request.auth.uid)));
        allow create: if isTenant(companyId) && isEmployeeActive();
        allow update, delete: if isTenant(companyId) && isAdminActive();
      }

      // workdays
      match /workdays/{id} {
        allow read: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && (isOwner(resource.data.userId) || resource.data.currentCompanionId == request.auth.uid)));
        allow create: if isTenant(companyId) && isEmployeeActive() && isOwner(request.resource.data.userId);
        allow update: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId)));
        allow delete: if isTenant(companyId) && isAdminActive();
      }

      // checkIns
      match /checkIns/{id} {
        allow read: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && (
          isOwner(resource.data.userId) ||
          (
            'scheduledServiceId' in resource.data && 
            resource.data.scheduledServiceId != null && 
            resource.data.scheduledServiceId != '' && 
            (
              get(/databases/$(database)/documents/companies/$(companyId)/scheduledServices/$(resource.data.scheduledServiceId)).data.assignedUserId == request.auth.uid ||
              (
                'companionIds' in get(/databases/$(database)/documents/companies/$(companyId)/scheduledServices/$(resource.data.scheduledServiceId)).data &&
                request.auth.uid in get(/databases/$(database)/documents/companies/$(companyId)/scheduledServices/$(resource.data.scheduledServiceId)).data.companionIds
              )
            )
          )
        )));
        allow write: if isTenant(companyId) && isAdminActive();
      }

      // dailyMileage
      match /dailyMileage/{id} {
        allow read: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId)));
        allow create: if isTenant(companyId) && isEmployeeActive() && isOwner(request.resource.data.userId);
        allow update: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId)));
        allow delete: if isTenant(companyId) && isAdminActive();
      }

      // materialRequests
      match /materialRequests/{id} {
        allow read: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId)));
        allow create: if isTenant(companyId) && isEmployeeActive() && isOwner(request.resource.data.userId);
        allow update: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId)));
        allow delete: if isTenant(companyId) && isAdminActive();
      }

      // transfers
      match /transfers/{id} {
        allow read: if isTenant(companyId) && (isAdminActive() || 
                    (isEmployeeActive() && (
                      resource.data.fromUserId == request.auth.uid || 
                      resource.data.toUserId == request.auth.uid || 
                      resource.data.userId == request.auth.uid
                    )));
        
        allow create: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && 
                      (
                        request.resource.data.fromUserId == request.auth.uid || 
                        request.resource.data.toUserId == request.auth.uid || 
                        request.resource.data.userId == request.auth.uid
                      )));
        
        allow update: if isTenant(companyId) && (isAdminActive() || 
                    (isEmployeeActive() && (
                      resource.data.fromUserId == request.auth.uid || 
                      resource.data.toUserId == request.auth.uid || 
                      resource.data.userId == request.auth.uid
                    )));
        
        allow delete: if isTenant(companyId) && isAdminActive();
      }

      // systemNotifications
      match /systemNotifications/{id} {
        allow read: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId)));
        allow create: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && isOwner(request.resource.data.userId)));
        allow update: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId)));
        allow delete: if isTenant(companyId) && isAdminActive();
      }

      // taskExecutions
      match /taskExecutions/{id} {
        allow read, write: if isTenant(companyId) && isEmployeeActive();
      }

      // settings
      match /settings/{id} {
        allow read: if isTenant(companyId) && (id == 'global' ? isEmployeeActive() : isAdminActive());
        allow write: if isTenant(companyId) && isAdminActive();
      }

      // invoices (VERIFACTU logic)
      match /invoices/{id} {
        allow read, create: if isTenant(companyId) && isAdminActive();
        allow update: if isTenant(companyId) && isAdminActive() && (
          resource.data.status == 'draft' ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        );
        allow delete: if isTenant(companyId) && isAdminActive() && resource.data.status == 'draft';
      }

      // products
      match /products/{id} {
        allow read: if isTenant(companyId) && isEmployeeActive();
        allow write: if isTenant(companyId) && isAdminActive();
      }

      // stockMovements
      match /stockMovements/{id} {
        allow read, write: if isTenant(companyId) && isAdminActive();
      }

      // absences
      match /absences/{id} {
        allow read: if isTenant(companyId) && isEmployeeActive();
        allow create: if isTenant(companyId) && isEmployeeActive() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isTenant(companyId) && isAdminActive();
      }

      // invoice_templates
      match /invoice_templates/{id} {
        allow read, write: if isTenant(companyId) && isAdminActive();
      }

      // documentVault
      match /documentVault/{id} {
        allow read: if isTenant(companyId) && isEmployeeActive();
        allow write: if isTenant(companyId) && isAdminActive();
      }

      // evidenceReports
      match /evidenceReports/{id} {
        allow read: if isTenant(companyId) && (isAdminActive() || (isEmployeeActive() && resource.data.userId == request.auth.uid));
        allow create: if isTenant(companyId) && isEmployeeActive();
        allow update, delete: if isTenant(companyId) && isAdminActive();
      }

      // publicPortals
      match /publicPortals/{id} {
        allow get: if true;
        allow write, list: if isTenant(companyId) && isAdminActive();
      }

      // administrators
      match /administrators/{id} {
        allow read, write: if isTenant(companyId) && isAdminActive();
      }
    }
  }
}
