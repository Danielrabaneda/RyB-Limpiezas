rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================================
    // FUNCTIONS
    // =========================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Role check: Admin
    // Using a get() to the users collection ensures we check the actual DB role
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if the document belongs to the requesting user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the user is a registered employee (admin or operario)
    function isEmployee() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'operario');
    }

    // Check if the user is active in the database
    function isActiveUser() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }

    // Helper to check if the user is an active employee
    function isEmployeeActive() {
      return isEmployee() && isActiveUser();
    }

    // Helper to check if the user is an active admin
    function isAdminActive() {
      return isAdmin() && isActiveUser();
    }

    // =========================================================================
    // RULES
    // =========================================================================
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // GEO DETECTIONS & FCM TOKENS
    // -------------------------------------------------------------------------
    match /geoDetections/{detectionId} {
      allow read: if isAdminActive() || (isEmployeeActive() && resource.data.userId == request.auth.uid);
      allow create, update: if isEmployeeActive() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdminActive();
    }

    match /fcmTokens/{tokenId} {
      allow read: if isAdminActive() || (isEmployeeActive() && resource.data.userId == request.auth.uid);
      allow create, update: if isEmployeeActive() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdminActive() || (isEmployeeActive() && resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      // Admins can do anything
      // Operarios need to read the list of other operarios to select companions
      allow read: if isEmployeeActive(); 
      // Permitir la creación de perfiles si el usuario se registra a sí mismo como operario o si es un admin activo
      allow create: if isAdminActive() || (isAuthenticated() && isOwner(userId) && request.resource.data.role == 'operario');
      allow delete: if isAdminActive();
      // Users can update their own profile (e.g. push tokens, active status), 
      // but preventing role escalation would require checking request.resource.data.role
      allow update: if isAdminActive() || (isEmployeeActive() && isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    // -------------------------------------------------------------------------
    // ACCESS CODES (Invitaciones para registro)
    // -------------------------------------------------------------------------
    match /accessCodes/{code} {
      // Permitir a cualquiera comprobar si un código específico es válido (get)
      // pero no listar todos los códigos (list) ni modificarlos (write)
      allow get: if true;
      allow list, write: if isAdminActive();
    }

    // -------------------------------------------------------------------------
    // COMMUNITIES & TASKS (Global Config)
    // -------------------------------------------------------------------------
    match /communities/{communityId} {
      allow read: if isEmployeeActive();
      allow write: if isAdminActive();
    }

    match /taskTemplates/{templateId} {
      allow read: if isEmployeeActive();
      allow write: if isAdminActive();
    }

    match /communityTasks/{taskId} {
      allow read: if isEmployeeActive();
      allow write: if isAdminActive();
    }

    match /assignments/{assignmentId} {
      allow read: if isEmployeeActive();
      allow write: if isAdminActive();
    }

    // -------------------------------------------------------------------------
    // SCHEDULED SERVICES
    // -------------------------------------------------------------------------
    match /scheduledServices/{serviceId} {
      // Only authenticated users can read schedules
      allow read, update: if isEmployeeActive();
      allow create, delete: if isAdminActive();
    }

    // -------------------------------------------------------------------------
    // GPS SUGGESTIONS
    // -------------------------------------------------------------------------
    match /gpsSuggestions/{suggestionId} {
      allow read: if isAdminActive() || (isEmployeeActive() && (resource.data.operarioUid == request.auth.uid || resource.data.userId == request.auth.uid));
      allow create: if isEmployeeActive();
      allow update, delete: if isAdminActive();
    }

    // -------------------------------------------------------------------------
    // USER SPECIFIC DATA (Workdays, Check-ins, Mileage, etc.)
    // -------------------------------------------------------------------------
    
    match /workdays/{workdayId} {
      allow read: if isAdminActive() || (isEmployeeActive() && (isOwner(resource.data.userId) || resource.data.currentCompanionId == request.auth.uid));
      allow create: if isEmployeeActive() && isOwner(request.resource.data.userId);
      allow update: if isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId));
      allow delete: if isAdminActive();
    }

    match /checkIns/{checkInId} {
      allow read: if isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId));
      allow create: if isEmployeeActive() && (
        isOwner(request.resource.data.userId) ||
        get(/databases/$(database)/documents/scheduledServices/$(request.resource.data.scheduledServiceId)).data.assignedUserId == request.auth.uid
      );
      allow update, delete: if isEmployeeActive() && (
        isAdminActive() || 
        isOwner(resource.data.userId) ||
        get(/databases/$(database)/documents/scheduledServices/$(resource.data.scheduledServiceId)).data.assignedUserId == request.auth.uid
      );
    }

    match /dailyMileage/{mileageId} {
      allow read: if isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId));
      allow create: if isEmployeeActive() && isOwner(request.resource.data.userId);
      allow update: if isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId));
      allow delete: if isAdminActive();
    }

    match /materialRequests/{requestId} {
      allow read: if isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId));
      allow create: if isEmployeeActive() && isOwner(request.resource.data.userId);
      allow update: if isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId));
      allow delete: if isAdminActive();
    }

    match /reports/{reportId} {
      allow read, write: if isAdminActive();
    }

    match /transfers/{transferId} {
      allow read: if isAdminActive() || 
                  (isEmployeeActive() && (
                    resource.data.fromUserId == request.auth.uid || 
                    resource.data.toUserId == request.auth.uid || 
                    resource.data.userId == request.auth.uid
                  ));
      
      allow create: if isAdminActive() || (isEmployeeActive() && 
                    (
                      request.resource.data.fromUserId == request.auth.uid || 
                      request.resource.data.toUserId == request.auth.uid || 
                      request.resource.data.userId == request.auth.uid
                    ));
      
      allow update: if isAdminActive() || 
                    (isEmployeeActive() && (
                      resource.data.fromUserId == request.auth.uid || 
                      resource.data.toUserId == request.auth.uid || 
                      resource.data.userId == request.auth.uid
                    ));
      
      allow delete: if isAdminActive();
    }

    match /systemNotifications/{notificationId} {
      allow read: if isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId));
      allow create: if isAdminActive() || (isEmployeeActive() && isOwner(request.resource.data.userId));
      allow update: if isAdminActive() || (isEmployeeActive() && isOwner(resource.data.userId));
      allow delete: if isAdminActive();
    }

    match /taskExecutions/{executionId} {
      allow read, write: if isEmployeeActive();
    }

    match /settings/{settingId} {
      allow read: if settingId == 'global' ? isEmployeeActive() : isAdminActive();
      allow write: if isAdminActive();
    }

    match /invoices/{invoiceId} {
      allow read, write: if isAdminActive();
    }

    match /products/{productId} {
      allow read: if isEmployeeActive();
      allow write: if isAdminActive();
    }

    match /stockMovements/{movementId} {
      allow read, write: if isAdminActive();
    }

    match /absences/{absenceId} {
      allow read: if isEmployeeActive();
      allow create: if isEmployeeActive() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdminActive();
    }

    match /invoice_templates/{templateId} {
      allow read, write: if isAdminActive();
    }

    match /documentVault/{documentId} {
      allow read: if isEmployeeActive();
      allow write: if isAdminActive();
    }

    match /evidenceReports/{reportId} {
      allow read: if isAdminActive() || (isEmployeeActive() && resource.data.userId == request.auth.uid);
      allow create: if isEmployeeActive();
      allow update, delete: if isAdminActive();
    }

    match /publicPortals/{token} {
      allow get: if true;
      allow write, list: if isAdminActive();
    }

    // -------------------------------------------------------------------------
    // ADMINISTRADORES DE FINCAS
    // -------------------------------------------------------------------------
    match /administrators/{adminId} {
      allow read, write: if isAdminActive();
    }

    // -------------------------------------------------------------------------
    // COMPANY REQUESTS (Leads de la Landing Page — escritura pública)
    // -------------------------------------------------------------------------
    match /companyRequests/{requestId} {
      allow create: if request.resource.data.keys().hasAll(['companyName', 'contactName', 'email', 'phone']) 
                    && request.resource.data.keys().size() <= 10
                    && request.resource.data.companyName is string && request.resource.data.companyName.size() < 200
                    && request.resource.data.contactName is string && request.resource.data.contactName.size() < 200
                    && request.resource.data.email is string && request.resource.data.email.size() < 200
                    && request.resource.data.phone is string && request.resource.data.phone.size() < 50;
      allow read, update, delete: if isAdminActive();
    }

    // -------------------------------------------------------------------------
    // OTHER / FUTURE COLLECTIONS
    // -------------------------------------------------------------------------
    // Add explicitly any other collections you use to avoid access denied
  }
}
